rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function maxSize(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    // ── User uploads (avatars, banners) ───────────────────────────────────
    match /user_uploads/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        isImage() &&
        maxSize(10);
    }

    // ── Group avatars ─────────────────────────────────────────────────────
    // Any group member can upload; groupId scopes the path.
    // If no avatar is uploaded, the client should fall back to DiceBear:
    //   https://api.dicebear.com/7.x/identicon/svg?seed={groupId}
    match /group_avatars/{groupId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        isImage() &&
        maxSize(5);
    }

    // ── Post media ────────────────────────────────────────────────────────
    match /posts/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        maxSize(250);
    }

    // ── Thumbnails ────────────────────────────────────────────────────────
    match /thumbnails/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        isImage() &&
        maxSize(5);
    }

    // ── Flashes (Stories) ─────────────────────────────────────────────────
    match /flashes/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        maxSize(50);
    }

    // ── Drops ─────────────────────────────────────────────────────────────
    match /drops/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        maxSize(75);
    }

    // ── Chat media ────────────────────────────────────────────────────────
    match /chat_media/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        maxSize(25);
    }

    // ── Voice messages ────────────────────────────────────────────────────
    match /voice_messages/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        maxSize(10);
    }

  }
}