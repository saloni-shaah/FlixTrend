rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFounder() {
      return isSignedIn() && request.auth.uid == 'x04gu2AkBFVX4y6Iho6J713cJOy2';
    }

    function onlyKeysChanged(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // ─────────────────────────────────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow get, list: if true;
      allow create:    if isOwner(userId);
      allow update:    if isOwner(userId);
      allow delete:    if isOwner(userId);

      match /{subcollection}/{docId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) ||
          (subcollection == 'followers' &&
           docId == request.auth.uid &&
           (request.method == 'create' || request.method == 'delete'));
      }

      match /playlists/{playlistId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // USERNAMES
    // ─────────────────────────────────────────────────────────────────────

    match /usernames/{username} {
      allow read:   if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // POSTS
    // ─────────────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow get, list: if true;

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;

      allow update: if isSignedIn() && (
        // Owner can change anything
        request.auth.uid == resource.data.userId

        // viewCount: owner-only to prevent farming
        // Prefer Cloud Function for real increments
        || (
          onlyKeysChanged(['viewCount']) &&
          request.auth.uid == resource.data.userId
        )
        // NOTE: commentCount is managed by Cloud Functions only — no client rule
      );

      allow delete: if isOwner(resource.data.userId);
    }

    // Posts subcollections (comments, likes, etc.)
    match /posts/{postId}/{subcollection}/{docId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        // For likes subcollection: doc ID must equal the user's own uid
        (subcollection != 'likes' || docId == request.auth.uid);

      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == 'comments' && onlyKeysChanged(['likes']))
      );

      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        // User can delete their own like doc via its uid path
        (subcollection == 'likes' && docId == request.auth.uid)
      );
    }

    // ─────────────────────────────────────────────────────────────────────
    // FLASHES (Stories)
    // ─────────────────────────────────────────────────────────────────────

    match /flashes/{flashId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;

      // viewCount handled by Cloud Function only
      allow update: if isOwner(resource.data.userId);

      allow delete: if isOwner(resource.data.userId);
    }

    // ─────────────────────────────────────────────────────────────────────
    // DROPS
    // ─────────────────────────────────────────────────────────────────────

    match /drops/{dropId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        // Reactions map: type-check only — move to subcollection for full safety
        (onlyKeysChanged(['reactions']) && request.resource.data.reactions is map)
      );

      allow delete: if isOwner(resource.data.userId);
    }

    // Drops subcollections (comments, likes, etc.)
    match /drops/{dropId}/{subcollection}/{docId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        (subcollection != 'likes' || docId == request.auth.uid);

      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == 'comments' && onlyKeysChanged(['likes']))
      );

      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == 'likes' && docId == request.auth.uid)
      );
    }

    // ─────────────────────────────────────────────────────────────────────
    // SONGS
    // ─────────────────────────────────────────────────────────────────────

    match /songs/{songId} {
      allow get:  if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // SINGERS (artist profiles)
    // ─────────────────────────────────────────────────────────────────────

    match /singers/{uid} {
      allow get:          if true;
      allow list:         if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete:       if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // GROUPS
    // ─────────────────────────────────────────────────────────────────────

    match /groups/{groupId} {
      allow read: if isSignedIn();

      // Creator must be in both members and admins
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.admins.hasAll([request.auth.uid]);

      allow update: if isSignedIn() && (
        // Admins can change anything
        request.auth.uid in resource.data.admins ||
        // Regular members can only update last message metadata
        (
          request.auth.uid in resource.data.members &&
          onlyKeysChanged(['lastMessage', 'lastMessageAt'])
        )
      );

      allow delete: if isSignedIn() &&
        resource.data.createdBy == request.auth.uid;

      match /typing/{userId} {
        allow read:  if isSignedIn() &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
        allow write: if isOwner(userId) &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // CHATS  (1:1 id = "uid1_uid2" sorted; group id = group doc id)
    // ─────────────────────────────────────────────────────────────────────

    match /chats/{chatId} {

      function isParticipant() {
        return (
          (chatId.matches('^[^_]+_[^_]+$') &&
           request.auth.uid in chatId.split('_'))
          ||
          (!chatId.matches('^[^_]+_[^_]+$') &&
           exists(/databases/$(database)/documents/groups/$(chatId)) &&
           request.auth.uid in
             get(/databases/$(database)/documents/groups/$(chatId)).data.members)
        );
      }

      match /typing/{userId} {
        allow read:   if isSignedIn() && isParticipant();
        allow write:  if isOwner(userId) && isParticipant();
        allow delete: if isOwner(userId);
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && isParticipant();

        allow create: if isSignedIn() &&
          isParticipant() &&
          request.resource.data.sender == request.auth.uid &&
          request.resource.data.createdAt == request.time;

        allow update: if isSignedIn() &&
          isParticipant() &&
          onlyKeysChanged(['reactions', 'deletedFor', 'readBy']);

        allow delete: if isSignedIn() &&
          resource.data.sender == request.auth.uid;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // POLLS
    // ─────────────────────────────────────────────────────────────────────

    match /drop_polls/{pollId} {
      allow read, create: if isSignedIn();

      match /votes/{voteId} {
        allow read:          if isSignedIn();
        allow create:        if isSignedIn() && voteId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // PROMPTS
    // ─────────────────────────────────────────────────────────────────────

    match /prompts/current {
      allow read:  if true;
      allow write: if isFounder();
    }

    match /dropPrompts/{promptId} {
      allow read:  if true;
      allow write: if isFounder();
    }

  }
}
