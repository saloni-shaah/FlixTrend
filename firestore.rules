rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFounder() {
      return request.auth.uid == 'x04gu2AkBFVX4y6Iho6J713cJOy2';
    }

    function onlyKeysChanged(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // ───────────────── USERS ─────────────────
    match /users/{userId} {
      allow get: if true; // public profile (SEO)
      allow list: if isSignedIn();
      allow create, update, delete: if isOwner(userId);

      match /{subcollection}/{docId} {
        allow read: if isSignedIn();

        allow write: if isOwner(userId) ||
          (subcollection == "followers" &&
           docId == request.auth.uid &&
           (request.method == "create" || request.method == "delete"));
      }

      match /playlists/{playlistId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // ───────────────── USERNAMES ─────────────────
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ───────────────── POSTS ─────────────────
    match /posts/{postId} {
      allow get, list: if true; // public feed

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;

      allow update: if isSignedIn() && (
        // owner full control
        request.auth.uid == resource.data.userId ||

        // like system (safe but simple)
        (
          onlyKeysChanged(['likes']) &&
          request.auth.uid in request.resource.data.likes
        ) ||

        // view count increment only
        (
          onlyKeysChanged(['viewCount']) &&
          request.resource.data.viewCount >= resource.data.viewCount
        ) ||

        // comment count increment only
        (
          onlyKeysChanged(['commentCount']) &&
          request.resource.data.commentCount >= resource.data.commentCount
        )
      );

      allow delete: if isOwner(resource.data.userId);
    }

    // posts subcollections
    match /posts/{postId}/{subcollection}/{docId} {
      allow read, create: if isSignedIn();

      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == "comments" &&
         onlyKeysChanged(['likes']))
      );

      allow delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    // ───────────────── FLASHES ─────────────────
    match /flashes/{flashId} {
      allow read: if isSignedIn(); // Flashes are private to signed-in users

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        (
          onlyKeysChanged(['viewCount']) &&
          request.resource.data.viewCount >= resource.data.viewCount
        )
      );

      allow delete: if isOwner(resource.data.userId);
    }

    // ───────────────── DROPS ─────────────────
    match /drops/{dropId} {
      allow get, list: if true; // SEO

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        (
          onlyKeysChanged(['likes']) &&
          request.auth.uid in request.resource.data.likes
        )
      );

      allow delete: if isOwner(resource.data.userId);
    }

    match /drops/{dropId}/{subcollection}/{docId} {
      allow read, create: if isSignedIn();

      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == "comments" &&
         onlyKeysChanged(['likes']))
      );

      allow delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    // ───────────────── SONGS ─────────────────
    match /songs/{songId} {
      allow get: if true; // public for SEO
      allow list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    // ───────────────── SINGERS ─────────────────
    match /singers/{uid} {
      allow get: if true; // public artist profile

      allow create, update: if isOwner(uid);
      allow list: if isSignedIn();
      allow delete: if false;
    }

    // ───────────────── GROUPS ─────────────────
    match /groups/{groupId} {
      allow read, create: if isSignedIn();

      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.members;

      allow delete: if isSignedIn() &&
        resource.data.createdBy == request.auth.uid;
    }

    // ───────────────── CHATS ─────────────────
    match /chats/{chatId} {

      function isParticipant() {
        return request.auth.uid in chatId.split('_') ||
          (exists(/databases/$(database)/documents/groups/$(chatId)) &&
           request.auth.uid in get(/databases/$(database)/documents/groups/$(chatId)).data.members);
      }

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && isParticipant();

        allow update: if isSignedIn() && isParticipant() &&
          onlyKeysChanged(['reactions', 'deletedFor', 'readBy']);

        allow delete: if isSignedIn() &&
          resource.data.sender == request.auth.uid;
      }
    }

    // ───────────────── POLLS ─────────────────
    match /drop_polls/{pollId} {
      allow read, create: if isSignedIn();

      match /votes/{voteId} {
        allow read, create: if isSignedIn();
      }
    }

    // ───────────────── PROMPTS ─────────────────
    match /prompts/current {
      allow read: if true;
      allow write: if isFounder();
    }

    match /dropPrompts/{promptId} {
      allow read: if true;
      allow write: if isFounder();
    }
  }
}