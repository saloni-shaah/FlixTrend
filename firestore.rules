rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFounder() {
      return isSignedIn() && request.auth.uid == 'x04gu2AkBFVX4y6Iho6J713cJOy2';
    }

    function onlyKeysChanged(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // ─────────────────────────────────────────────────────────────────────
    // APP STATUS
    // ─────────────────────────────────────────────────────────────────────

    match /app_status/{docId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && onlyKeysChanged(['totalUsers']);
    }

    // ─────────────────────────────────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow get, list: if true;
      allow create:    if isOwner(userId);
      allow update:    if isOwner(userId);
      allow delete:    if isOwner(userId);

      // General subcollections
      match /{subcollection}/{docId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) ||
          (subcollection == 'followers' &&
           docId == request.auth.uid &&
           (request.method == 'create' || request.method == 'delete'));
      }

      // Playlists: private to owner only
      match /playlists/{playlistId} {
        allow read, write: if isOwner(userId);
      }

      // Notifications: only the owning user can read or delete; no client writes
      match /notifications/{notifId} {
        allow read:   if isOwner(userId);
        allow create: if false;  // written by Cloud Functions (Admin SDK) only
        allow update: if isOwner(userId) && onlyKeysChanged(['isRead']);
        allow delete: if isOwner(userId);
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // USERNAMES
    // ─────────────────────────────────────────────────────────────────────

    match /usernames/{username} {
      allow read:   if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // POSTS
    // ─────────────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow get, list: if true;

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId
      );

      allow delete: if isOwner(resource.data.userId);
    }

    // Posts subcollections
    match /posts/{postId}/{subcollection}/{docId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        (subcollection != 'likes' || docId == request.auth.uid);

      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == 'comments' && onlyKeysChanged(['likes']))
      );

      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == 'likes' && docId == request.auth.uid)
      );
    }

    match /posts/{postId}/viewShards/{shardId} {
      allow read:  if true;
      allow write: if false; // Admin SDK only
    }

    // ─────────────────────────────────────────────────────────────────────
    // FLASHES (Stories)
    // ─────────────────────────────────────────────────────────────────────

    match /flashes/{flashId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ─────────────────────────────────────────────────────────────────────
    // DROPS
    // ─────────────────────────────────────────────────────────────────────

    match /drops/{dropId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        (onlyKeysChanged(['reactions']) && request.resource.data.reactions is map)
      );

      allow delete: if isOwner(resource.data.userId);
    }

    match /drops/{dropId}/{subcollection}/{docId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        (subcollection != 'likes' || docId == request.auth.uid);

      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == 'comments' && onlyKeysChanged(['likes']))
      );

      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (subcollection == 'likes' && docId == request.auth.uid)
      );
    }

    // ─────────────────────────────────────────────────────────────────────
    // SONGS
    // ─────────────────────────────────────────────────────────────────────

    match /songs/{songId} {
      allow get:    if true;
      allow list:   if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // SINGERS
    // ─────────────────────────────────────────────────────────────────────

    match /singers/{uid} {
      allow get:            if true;
      allow list:           if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete:         if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // GROUPS
    // ─────────────────────────────────────────────────────────────────────

    match /groups/{groupId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.admins.hasAll([request.auth.uid]);

      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.admins ||
        (
          request.auth.uid in resource.data.members &&
          onlyKeysChanged(['lastMessage', 'lastMessageAt'])
        )
      );

      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /typing/{userId} {
        allow read: if isSignedIn() &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
        allow write: if isOwner(userId) &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAny([request.auth.uid]);
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // CHATS
    // ─────────────────────────────────────────────────────────────────────

    match /chats/{chatId} {

      function isParticipant() {
        return (
          (chatId.matches('^[^_]+_[^_]+$') &&
           request.auth.uid in chatId.split('_'))
          ||
          (!chatId.matches('^[^_]+_[^_]+$') &&
           exists(/databases/$(database)/documents/groups/$(chatId)) &&
           request.auth.uid in
             get(/databases/$(database)/documents/groups/$(chatId)).data.members)
        );
      }

      // ── Chat document itself (DM bootstrap) ──────────────────────────
      allow read: if isSignedIn() && isParticipant();

      // DMs: either participant can create/merge the chat doc
      allow create: if isSignedIn() &&
        chatId.matches('^[^_]+_[^_]+$') &&
        request.auth.uid in chatId.split('_');

      // Allow merge-updates (e.g. setDoc with merge:true) from participants
      allow update: if isSignedIn() &&
        chatId.matches('^[^_]+_[^_]+$') &&
        request.auth.uid in chatId.split('_');

      match /typing/{userId} {
        allow read:   if isSignedIn() && isParticipant();
        allow write:  if isOwner(userId) && isParticipant();
        allow delete: if isOwner(userId);
      }

      // DM read receipts — lastReadAt per user, replaces per-message readBy
      match /readReceipts/{uid} {
        allow read: if isSignedIn() && isParticipant();
        
        allow create: if isOwner(uid) && isParticipant();
        
        allow update: if isOwner(uid) && isParticipant() 
          && onlyKeysChanged(['lastReadAt']);
          
        allow delete: if isOwner(uid);
      }

      match /groupReads/{uid} {
        allow read: if isSignedIn() &&
          isParticipant();

        allow create: if isOwner(uid) &&
          isParticipant();

        allow update: if isOwner(uid) &&
          isParticipant() &&
          onlyKeysChanged([
            'lastReadAt'
          ]);

        allow delete: if isOwner(uid);
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && isParticipant();

        allow create: if isSignedIn() &&
          isParticipant() &&
          request.resource.data.sender == request.auth.uid &&
          request.resource.data.createdAt == request.time;

        allow update: if isSignedIn() &&
          isParticipant() &&
          onlyKeysChanged([
            'reactions',
            'deletedFor',
            'isStarred'
          ]);

        allow delete: if isSignedIn() &&
          resource.data.sender == request.auth.uid;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // POLLS
    // ─────────────────────────────────────────────────────────────────────

    match /drop_polls/{pollId} {
      allow read, create: if isSignedIn();

      match /votes/{voteId} {
        allow read:           if isSignedIn();
        allow create:         if isSignedIn() && voteId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // PROMPTS
    // ─────────────────────────────────────────────────────────────────────

    match /prompts/current {
      allow read:  if true;
      allow write: if isFounder();
    }

    match /dropPrompts/{promptId} {
      allow read:  if true;
      allow write: if isFounder();
    }

  }
}